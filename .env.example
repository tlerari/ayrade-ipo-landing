# ═══════════════════════════════════════════════════════════════════════
# ipo.ayrade.com — Variables d'environnement
# ═══════════════════════════════════════════════════════════════════════

# Phase de l'opération — voir lib/operationPhase.ts
# Valeurs : pre-quiet | quiet | subscription | post-close | post-listing | auto
# "auto" = phase calculée automatiquement à partir de la date courante
OPERATION_PHASE=auto

# Numéro de visa COSOB (à remplir dès réception — vers le 10-15 mai 2026)
NEXT_PUBLIC_COSOB_VISA_NUMBER=

# Analytics — Plausible self-hosted (souveraineté données)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=ipo.ayrade.com
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.ayrade.com/js/script.js

# Newsletter — endpoint backend AYRADE (à fournir par l'IT)
NEWSLETTER_API_URL=
NEWSLETTER_API_TOKEN=

# URL canonical du site
NEXT_PUBLIC_SITE_URL=https://ipo.ayrade.com

# ─── Preview / staging uniquement ──────────────────────────────────────
# Mot de passe de pré-visualisation (Basic Auth). Laisser vide en local
# pour désactiver la protection. À définir sur Vercel preview/prod.
# PREVIEW_USERNAME=ayrade   # optionnel, défaut "ayrade"
PREVIEW_PASSWORD=
